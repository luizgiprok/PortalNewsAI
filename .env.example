# NewsAPI Configuration
# Get your free API key at: https://newsapi.org/

# Free tier: 100 requests/day, 1 request/second
NEWS_API_KEY=your_newsapi_key_here

# NewsAPI Sources (optional - filter by specific sources)
# Example: bbc-news, cnn, reuters, the-verge, techcrunch
NEWS_API_SOURCES=bbc-news,cnn,reuters,the-verge,techcrunch

# NewsAPI Language
# pt = Portuguese, en = English, es = Spanish, etc.
NEWS_API_LANGUAGE=pt

# NewsAPI Query
# Default search query
NEWS_API_QUERY=technology OR business OR politics OR sports